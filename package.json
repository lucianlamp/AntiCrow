{
  "name": "anti-crow",
  "displayName": "AntiCrow",
  "description": "Discord→Antigravity自動操作ブリッジ。自然文で依頼→定期/即時実行→結果通知。",
  "version": "0.1.0",
  "publisher": "ytvar",
  "icon": "images/AntiCrowIcon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "anti-crow.start",
        "title": "Start",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.stop",
        "title": "Stop",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.setToken",
        "title": "Set Bot Token",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.showPlans",
        "title": "Show Plans",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.clearPlans",
        "title": "Clear All Plans",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.createShortcut",
        "title": "Create Desktop Shortcut",
        "category": "AntiCrow"
      }
    ],
    "configuration": {
      "title": "AntiCrow",
      "properties": {
        "antiCrow.botToken": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Bot Token 設定状態（SecretStorage に暗号化保存）。\n\nトークンを設定するには、コマンドパレット（`Ctrl+Shift+P`）から **[AntiCrow: Set Bot Token](command:anti-crow.setToken)** を実行してください。\n\n設定完了後、このチェックボックスは自動的にオンになります。"
        },
        "antiCrow.timezone": {
          "type": "string",
          "default": "",
          "description": "CRON実行のタイムゾーン（IANA形式）。空の場合はOSの設定から自動取得します。"
        },
        "antiCrow.responseTimeoutMs": {
          "type": "number",
          "default": 1800000,
          "description": "最後の進捗更新からのアイドルタイムアウト（ミリ秒）。進捗報告がある限りリセットされます。デフォルト30分。"
        },
        "antiCrow.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "VS Code起動時に自動でブリッジを開始する"
        },
        "antiCrow.clientId": {
          "type": "string",
          "default": "",
          "description": "Discord Application の Client ID（スラッシュコマンド登録に必要）。Developer Portal で確認できます。"
        },
        "antiCrow.categoryArchiveDays": {
          "type": "number",
          "default": 7,
          "description": "ワークスペースカテゴリーの自動アーカイブ日数。この日数以上使用されていないカテゴリーは自動削除されます。0で無効。"
        },
        "antiCrow.allowedUserIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "メッセージ処理を許可する Discord ユーザーID一覧。空の場合は全ユーザーを許可。Developer Mode でユーザーIDをコピーできます。"
        },
        "antiCrow.autoClickRules": {
          "type": "array",
          "default": [
            {
              "name": "continue-warning",
              "text": "Continue",
              "tag": "button",
              "inCascade": true
            },
            {
              "name": "allow-tool",
              "text": "Allow",
              "tag": "button",
              "inCascade": true
            },
            {
              "name": "retry-error",
              "text": "Retry",
              "tag": "button",
              "inCascade": true
            },
            {
              "name": "expand-all",
              "selector": "[aria-label=\"Expand All\"]",
              "tag": "button",
              "inCascade": false
            },
            {
              "name": "expand-step-input",
              "text": "Expand",
              "tag": "button",
              "inCascade": true
            }
          ],
          "markdownDescription": "タスク実行中に自動クリックするボタンのルール一覧。確認ダイアログ（Continue, Allow 等）を自動的に承認します。\n\n各ルールのプロパティ:\n- `name`: ルール名（識別用）\n- `text`: ボタンのテキスト（部分一致）\n- `selector`: CSS セレクタ（高度な指定用）\n- `tag`: HTML タグ名（例: `button`）\n- `inCascade`: 実行パネル内に限定するか（デフォルト: true）",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "ルール名（識別用）"
              },
              "text": {
                "type": "string",
                "description": "ボタンのテキスト（部分一致）"
              },
              "selector": {
                "type": "string",
                "description": "CSS セレクタ（高度な指定用）"
              },
              "tag": {
                "type": "string",
                "description": "HTML タグ名（例: button）"
              },
              "inCascade": {
                "type": "boolean",
                "description": "実行パネル内のボタンに限定するか",
                "default": true
              }
            },
            "required": [
              "name"
            ]
          }
        },
        "antiCrow.autoAcceptCommands": {
          "type": "boolean",
          "default": false,
          "description": "タスク実行中にエージェント提案を自動承認するコマンド呼び出しを有効にする。有効にすると、自動クリックルールに加えてコマンド経由でも提案を自動承認します。"
        },
        "antiCrow.maxRetries": {
          "type": "number",
          "default": 1,
          "description": "タイムアウトやCDP切断時の自動リトライ回数（0でリトライ無効）。"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "node ./esbuild.js",
    "package": "npx -y @vscode/vsce package --no-dependencies --allow-missing-repository --skip-license --baseContentUrl \".\" --baseImagesUrl \".\"",
    "deploy": "npm run compile && npm run bundle && npm run package && antigravity --install-extension anti-crow-0.1.0.vsix --force",
    "test": "vitest run",
    "vscode:prepublish": "npm run typecheck && npm run bundle"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.20.2",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  }
}