{
  "name": "anti-crow",
  "displayName": "AntiCrow",
  "description": "Discord→Antigravity自動操作ブリッジ。自然文で依頼→定期/即時実行→結果通知。",
  "version": "0.1.0",
  "publisher": "lucianlamp",
  "author": "lucianlamp",
  "icon": "images/AntiCrowIcon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "anti-crow.start",
        "title": "Start",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.stop",
        "title": "Stop",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.setToken",
        "title": "Set Bot Token",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.showPlans",
        "title": "Show Plans",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.clearPlans",
        "title": "Clear All Plans",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.createShortcut",
        "title": "Create Desktop Shortcut",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.dumpCommands",
        "title": "Dump Antigravity Commands (Diagnostic)",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.licenseInfo",
        "title": "License Info",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.licenseLogin",
        "title": "License Login",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.licensePurchase",
        "title": "Purchase License",
        "category": "AntiCrow"
      },
      {
        "command": "anti-crow.licenseLogout",
        "title": "License Logout",
        "category": "AntiCrow"
      }
    ],
    "configuration": {
      "title": "AntiCrow",
      "properties": {
        "antiCrow.botToken": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Bot Token 設定状態（SecretStorage に暗号化保存）。\n\nトークンを設定するには、コマンドパレット（`Ctrl+Shift+P`）から **[AntiCrow: Set Bot Token](command:anti-crow.setToken)** を実行してください。\n\n設定完了後、このチェックボックスは自動的にオンになります。"
        },
        "antiCrow.responseTimeoutMs": {
          "type": "number",
          "default": 1800000,
          "description": "最後の進捗更新からのアイドルタイムアウト（ミリ秒）。進捗報告がある限りリセットされます。デフォルト30分。"
        },
        "antiCrow.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "VS Code起動時に自動でブリッジを開始する"
        },
        "antiCrow.categoryArchiveDays": {
          "type": "number",
          "default": 7,
          "description": "ワークスペースカテゴリーの自動アーカイブ日数。この日数以上使用されていないカテゴリーは自動削除されます。0で無効。"
        },
        "antiCrow.allowedUserIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "メッセージ処理を許可する Discord ユーザーID一覧。空の場合は全ユーザーを拒否（セキュリティ保護）。Developer Mode でユーザーIDをコピーできます。"
        },
        "antiCrow.autoAccept": {
          "type": "boolean",
          "default": false,
          "description": "自動承認（Continue / Allow / 提案承認など）を有効にする。ANTICROW 経由のジョブ実行中のみ動作します。手動操作時は自動承認されません。"
        },
        "antiCrow.maxRetries": {
          "type": "number",
          "default": 0,
          "description": "タイムアウトや接続断時の自動リトライ回数（0でリトライ無効、デフォルト: 0）。"
        },
        "antiCrow.cdpPort": {
          "type": "number",
          "default": 9333,
          "markdownDescription": "CDP（Chrome DevTools Protocol）接続に使用する固定ポート番号。Antigravity 起動時に `--remote-debugging-port` に使用されます。"
        },
        "antiCrow.workspaceParentDirs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "新規ワークスペース作成時のフォルダ配置先ディレクトリです。例: `C:\\Users\\user\\dev`, `C:\\Users\\user\\projects`"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "node ./esbuild.js",
    "package": "npx -y @vscode/vsce package --no-dependencies --allow-missing-repository --skip-license --baseContentUrl \".\" --baseImagesUrl \".\"",
    "deploy": "npm run compile && npm run bundle && npm run package && antigravity --install-extension anti-crow-0.1.0.vsix --force",
    "test": "vitest run",
    "vscode:prepublish": "npm run typecheck && npm run bundle",
    "setup:licensing": "npx tsx scripts/setup-licensing.ts"
  },
  "dependencies": {
    "@clerk/clerk-js": "^5.124.0",
    "chrome-remote-interface": "^0.34.0",
    "discord.js": "^14.16.3",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3",
    "stripe": "^20.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "esbuild": "^0.20.2",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  }
}