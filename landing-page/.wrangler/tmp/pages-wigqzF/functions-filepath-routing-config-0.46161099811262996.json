{
  "routes": [
    {
      "routePath": "/api/waitlist/register",
      "mountPath": "/api/waitlist",
      "method": "OPTIONS",
      "module": [
        "api/waitlist/register.ts:onRequestOptions"
      ]
    },
    {
      "routePath": "/api/waitlist/register",
      "mountPath": "/api/waitlist",
      "method": "POST",
      "module": [
        "api/waitlist/register.ts:onRequestPost"
      ]
    },
    {
      "routePath": "/api/waitlist/status",
      "mountPath": "/api/waitlist",
      "method": "GET",
      "module": [
        "api/waitlist/status.ts:onRequestGet"
      ]
    },
    {
      "routePath": "/api/waitlist/status",
      "mountPath": "/api/waitlist",
      "method": "OPTIONS",
      "module": [
        "api/waitlist/status.ts:onRequestOptions"
      ]
    }
  ],
  "baseURL": "/"
}